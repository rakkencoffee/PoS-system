// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  slug      String     @unique
  icon      String     @default("☕")
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  items     MenuItem[]
}

model MenuItem {
  id            Int             @id @default(autoincrement())
  name          String
  description   String          @default("")
  price         Float
  image         String          @default("")
  categoryId    Int
  isAvailable   Boolean         @default(true)
  isBestSeller  Boolean         @default(false)
  isRecommended Boolean         @default(false)
  type          String          @default("both") // hot, iced, both
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  category      Category        @relation(fields: [categoryId], references: [id])
  sizes         MenuItemSize[]
  orderItems    OrderItem[]
}

model MenuItemSize {
  id              Int      @id @default(autoincrement())
  menuItemId      Int
  size            String   // S, M, L
  priceAdjustment Float    @default(0)
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model Topping {
  id                Int                @id @default(autoincrement())
  name              String
  price             Float
  isAvailable       Boolean            @default(true)
  orderItemToppings OrderItemTopping[]
}

model Order {
  id            Int         @id @default(autoincrement())
  queueNumber   Int
  status        String      @default("PENDING") // PENDING, PREPARING, READY, COMPLETED
  totalAmount   Float
  paymentMethod String      @default("QRIS")
  customerName  String      @default("")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id          Int                @id @default(autoincrement())
  orderId     Int
  menuItemId  Int
  quantity    Int                @default(1)
  size        String             @default("M")
  sugarLevel  Int                @default(100) // 0, 25, 50, 75, 100
  iceLevel    String             @default("normal") // none, less, normal, more
  extraShot   Boolean            @default(false)
  notes       String             @default("")
  subtotal    Float
  order       Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem    MenuItem           @relation(fields: [menuItemId], references: [id])
  toppings    OrderItemTopping[]
}

model OrderItemTopping {
  id          Int       @id @default(autoincrement())
  orderItemId Int
  toppingId   Int
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  topping     Topping   @relation(fields: [toppingId], references: [id])
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
